{
    "Experiment": {
        "type": "EXPERIMENT",
        "enable_save": false,
        "save_dir": "./recordings",
        "timed_modes": [
            {
                "label": "Text Routine",
                "duration": "20s",
                "instruction": {
                    "type": "text",
                    "file": "instructions/sample_text.txt",
                    "font_size": 36,
                    "line_gap": 3
                }
            },
            {
                "label": "Audio Routine",
                "duration": "2.5m",
                "instruction": {
                    "type": "audio",
                    "file": "instructions/sample_audio.mp3",
                    "loop": true
                }
            },
            {
                "label": "Video Routine",
                "duration": "30s",
                "instruction": {
                    "type": "video",
                    "file": "instructions/sample_video.mp4",
                    "loop": false
                }
            }
        ]
    },
    "DummyDevice": {
        "type": "DUMMY",
        "samp_rate": 500,
        "num_channels": 4,
        "signal_freq": 1.0,
        "amplitude": 1.0,
        "noise_std": 0.02,
        "chunk_duration": 0.05
    }
}
